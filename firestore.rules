rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['telegramId', 'firstName', 'balance', 'updatedAt']) &&
             data.telegramId is string &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.balance is number &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.balance == 9000000.0;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        // Allow updating only balance and updatedAt during game or sync
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt', 'firstName', 'lastName', 'username', 'photoUrl'])
      );

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && 
          request.resource.data.userId == userId &&
          request.resource.data.amount is number &&
          request.resource.data.type in ['win', 'loss', 'deposit', 'withdrawal', 'purchase'] &&
          request.resource.data.timestamp == request.time;
      }
    }
  }
}
